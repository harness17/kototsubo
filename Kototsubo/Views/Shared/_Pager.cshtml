@model PagerViewModel

@if (Model.TotalPages > 1)
{
    var currentPage = Math.Clamp(Model.CurrentPage, 1, Model.TotalPages);
    var windowStart = Math.Max(1, currentPage - Model.WindowRadius);
    var windowEnd = Math.Min(Model.TotalPages, currentPage + Model.WindowRadius);

    <nav aria-label="@Model.AriaLabel">
        <ul class="pagination pagination-sm justify-content-center flex-wrap mb-3">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                @if (currentPage > 1)
                {
                    <a class="page-link" asp-action="@Model.Action"
                       asp-all-route-data="@Model.RouteValues"
                       asp-route-page="@(currentPage - 1)">前へ</a>
                }
                else
                {
                    <span class="page-link">前へ</span>
                }
            </li>

            @if (windowStart > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="@Model.Action"
                       asp-all-route-data="@Model.RouteValues"
                       asp-route-page="1">1</a>
                </li>
                if (windowStart > 2)
                {
                    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                }
            }

            @for (var pageNumber = windowStart; pageNumber <= windowEnd; pageNumber++)
            {
                <li class="page-item @(pageNumber == currentPage ? "active" : "")">
                    @if (pageNumber == currentPage)
                    {
                        <span class="page-link" aria-current="page">@pageNumber</span>
                    }
                    else
                    {
                        <a class="page-link" asp-action="@Model.Action"
                           asp-all-route-data="@Model.RouteValues"
                           asp-route-page="@pageNumber">@pageNumber</a>
                    }
                </li>
            }

            @if (windowEnd < Model.TotalPages)
            {
                if (windowEnd < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                }
                <li class="page-item">
                    <a class="page-link" asp-action="@Model.Action"
                       asp-all-route-data="@Model.RouteValues"
                       asp-route-page="@Model.TotalPages">@Model.TotalPages</a>
                </li>
            }

            <li class="page-item @(currentPage >= Model.TotalPages ? "disabled" : "")">
                @if (currentPage < Model.TotalPages)
                {
                    <a class="page-link" asp-action="@Model.Action"
                       asp-all-route-data="@Model.RouteValues"
                       asp-route-page="@(currentPage + 1)">次へ</a>
                }
                else
                {
                    <span class="page-link">次へ</span>
                }
            </li>
        </ul>
    </nav>
}
