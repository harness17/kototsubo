@model KindleImportViewModel

@{
    ViewData["Title"] = "Kindle 一括登録";
}

<h1 class="h3 mb-3">Kindle 一括登録</h1>

<div class="card">
    <div class="card-body">
        <p>kindle-series-sale-tracker が出力した CSV または JSON ファイルを選択してください。</p>
        <form asp-action="Kindle" method="post" enctype="multipart/form-data"
              data-loading-text="ファイルを解析中…">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="File" class="form-label">インポートファイル</label>
                <input asp-for="File" class="form-control" accept=".csv,.json,text/csv,application/json" />
                <span asp-validation-for="File" class="text-danger"></span>
                <div class="form-text">CSV/JSON、最大10MB。アップロード後に登録内容を確認できます。</div>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-list-check me-1"></i>プレビュー
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
