@model KindleImportPreviewViewModel

@{
    ViewData["Title"] = "Kindle 一括登録プレビュー";
}

<h1 class="h3 mb-3">登録内容の確認</h1>

<div class="alert alert-info">
    登録候補 @Model.Rows.Count 件、重複スキップ @Model.SkipCount 件です。
</div>

@if (Model.EnrichmentFailedCount > 0)
{
    <div class="alert alert-warning">
        @Model.EnrichmentFailedCount 件は書誌情報の取得に一時的に失敗し、補完が完了していません（対象は「補完未完了」の印で表示）。
        Kindleのタイトル・著者のまま登録可能です。書誌情報を補いたい場合はしばらくしてから再度お試しください。
    </div>
}

<form asp-action="KindleConfirm" method="post" data-loading-text="一括登録中…">
    <input asp-for="TempFilePath" type="hidden" />
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead>
                <tr>
                    <th>登録</th>
                    <th>タイトル</th>
                    <th>著者</th>
                    <th>ASIN</th>
                    <th>ISBN / 出版社</th>
                    <th>シリーズ / 巻</th>
                    <th>取得日時</th>
                    <th>状態</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr class="@(row.IsDuplicate ? "table-secondary" : "")">
                        <td>
                            @if (row.IsDuplicate)
                            {
                                <span class="badge bg-secondary">重複</span>
                            }
                            else
                            {
                                <input class="form-check-input" type="checkbox"
                                       name="SelectedAsins" value="@row.ASIN" checked />
                            }
                        </td>
                        <td>@row.Title</td>
                        <td>@row.Creator</td>
                        <td><code>@row.ASIN</code></td>
                        <td>
                            @if (!string.IsNullOrEmpty(row.ISBN))
                            {
                                <span class="badge bg-success me-1">ISBN</span>
                                <code class="small">@row.ISBN</code>
                                @if (!string.IsNullOrEmpty(row.Publisher))
                                {
                                    <br /><small class="text-muted">@row.Publisher</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>@row.Series @(row.Volume.HasValue ? $"({row.Volume}巻)" : "")</td>
                        <td>@row.AcquiredTime?.ToString("yyyy/MM/dd HH:mm")</td>
                        <td>
                            @row.ReadStatus
                            @if (row.EnrichmentFailed)
                            {
                                <br /><span class="badge bg-warning text-dark">補完未完了</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <button type="submit" class="btn btn-primary">
        <i class="fas fa-file-import me-1"></i>選択した所蔵品を登録
    </button>
    <a asp-action="Kindle" class="btn btn-outline-secondary">戻る</a>
</form>
