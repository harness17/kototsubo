@model ItemViewModel
@{
    ViewData["Title"] = "所蔵品削除";
}

<h2><i class="fas fa-trash me-2 text-danger"></i>所蔵品削除</h2>
<hr />

<div class="alert alert-warning">
    <i class="fas fa-exclamation-triangle me-1"></i>以下の所蔵品を削除します。この操作は取り消せません。
</div>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">タイトル</dt>
            <dd class="col-sm-9"><strong>@Model.Title</strong></dd>
            <dt class="col-sm-3">メディア種別</dt>
            <dd class="col-sm-9">
                <span class="badge bg-secondary">@Html.DisplayFor(m => m.MediaType)</span>
                @if (Model.IsDigital) { <span class="badge bg-info ms-1">デジタル</span> }
            </dd>
            <dt class="col-sm-3">クリエイター</dt>
            <dd class="col-sm-9">@(Model.Creator ?? "—")</dd>
            <dt class="col-sm-3">出版社</dt>
            <dd class="col-sm-9">@(Model.Publisher ?? "—")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>削除する</button>
    <a asp-action="Index" asp-route-returnList="true" class="btn btn-outline-secondary ms-2">キャンセル</a>
</form>
