@model ItemViewModel
@{
    ViewData["Title"] = "所蔵品登録";
}

<h2><i class="fas fa-plus me-2"></i>所蔵品登録</h2>
<hr />

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("_ItemForm", Model)
    <div class="mt-3">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>登録</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">キャンセル</a>
    </div>
</form>

@section Scripts {
    <partial name="_ItemFormScripts" />
}
