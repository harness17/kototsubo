@model ItemListViewModel
@{
    ViewData["Title"] = "所蔵品一覧";
    var currentSort = Model.Pager.sort ?? "";
    var currentDir = Model.Pager.sortdir ?? "ASC";
    string SortDir(string col) => currentSort.Equals(col, StringComparison.OrdinalIgnoreCase) && currentDir == "ASC" ? "DESC" : "ASC";
    string SortIcon(string col)
    {
        if (!currentSort.Equals(col, StringComparison.OrdinalIgnoreCase)) return "";
        return currentDir == "ASC" ? "fa-sort-up" : "fa-sort-down";
    }

    var pagerRouteValues = new Dictionary<string, string>();
    if (!string.IsNullOrWhiteSpace(Model.Pager.sort)) pagerRouteValues["sort"] = Model.Pager.sort;
    if (!string.IsNullOrWhiteSpace(Model.Pager.sortdir)) pagerRouteValues["sortdir"] = Model.Pager.sortdir;
    if (!string.IsNullOrWhiteSpace(Model.Search.Keyword)) pagerRouteValues["Search.Keyword"] = Model.Search.Keyword;
    if (Model.Search.MediaType.HasValue) pagerRouteValues["Search.MediaType"] = Model.Search.MediaType.Value.ToString();
    if (Model.Search.IsDigital.HasValue) pagerRouteValues["Search.IsDigital"] = Model.Search.IsDigital.Value.ToString();
    if (Model.Search.OwnershipStatus.HasValue) pagerRouteValues["Search.OwnershipStatus"] = Model.Search.OwnershipStatus.Value.ToString();
    if (!string.IsNullOrWhiteSpace(Model.Search.Publisher)) pagerRouteValues["Search.Publisher"] = Model.Search.Publisher;
    if (Model.Search.ReleaseDateFrom.HasValue) pagerRouteValues["Search.ReleaseDateFrom"] = Model.Search.ReleaseDateFrom.Value.ToString("yyyy-MM-dd");
    if (Model.Search.ReleaseDateTo.HasValue) pagerRouteValues["Search.ReleaseDateTo"] = Model.Search.ReleaseDateTo.Value.ToString("yyyy-MM-dd");

    var pager = new PagerViewModel
    {
        CurrentPage = Model.Pager.page,
        TotalPages = Model.Summary != null && Model.Pager.recoedNumber > 0
            ? (int)Math.Ceiling((double)Model.Summary.TotalRecords / Model.Pager.recoedNumber)
            : 0,
        Action = "Index",
        AriaLabel = "所蔵品一覧ページング",
        RouteValues = pagerRouteValues
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="fas fa-boxes-stacked me-2"></i>所蔵品一覧</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>新規登録
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Index" method="get" class="card mb-3">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label asp-for="Search.Keyword" class="form-label"></label>
                <input asp-for="Search.Keyword" class="form-control" placeholder="タイトル・著者・ISBN..." />
            </div>
            <div class="col-md-3">
                <label asp-for="Search.MediaType" class="form-label"></label>
                <select asp-for="Search.MediaType" asp-items="Html.GetEnumSelectList<MediaType>()" class="form-select">
                    <option value="">すべて</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="Search.IsDigital" class="form-label"></label>
                <select asp-for="Search.IsDigital" class="form-select">
                    <option value="">両方</option>
                    <option value="true">デジタル版</option>
                    <option value="false">物理版</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="Search.OwnershipStatus" class="form-label"></label>
                <select asp-for="Search.OwnershipStatus" asp-items="Html.GetEnumSelectList<OwnershipStatus>()" class="form-select">
                    <option value="">すべて</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="Search.Publisher" class="form-label"></label>
                <input asp-for="Search.Publisher" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Search.ReleaseDateFrom" class="form-label"></label>
                <input asp-for="Search.ReleaseDateFrom" class="form-control" type="date" />
                <span asp-validation-for="Search.ReleaseDateFrom" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Search.ReleaseDateTo" class="form-label"></label>
                <input asp-for="Search.ReleaseDateTo" class="form-control" type="date" />
                <span asp-validation-for="Search.ReleaseDateTo" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-secondary w-100">
                    <i class="fas fa-search me-1"></i>検索
                </button>
            </div>
        </div>
    </div>
</form>

@if (Model.Summary != null)
{
    <p class="text-muted small">@Model.Summary.Summary</p>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="text-center text-muted py-5">
        <i class="fas fa-circle-exclamation fa-3x mb-3"></i>
        <p class="lead">検索条件を確認してください</p>
    </div>
}
else if (Model.Items.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="fas fa-inbox fa-3x mb-3"></i>
        <p class="lead">所蔵品がまだ登録されていません</p>
    </div>
}
else
{
    <partial name="_Pager" model="pager" />

    <div class="table-responsive">
        <table class="table table-striped table-hover table-fixed">
            <colgroup>
                <col style="width:30%" />
                <col style="width:15%" />
                <col style="width:18%" />
                <col style="width:12%" />
                <col style="width:12%" />
                <col style="width:100px" />
            </colgroup>
            <thead class="table-dark">
                <tr>
                    <th>
                        <a asp-action="Index" asp-route-sort="title" asp-route-sortdir="@SortDir("title")"
                           asp-route-page="1" asp-route-Search.Keyword="@Model.Search.Keyword"
                           asp-route-Search.MediaType="@Model.Search.MediaType"
                           asp-route-Search.IsDigital="@Model.Search.IsDigital"
                           asp-route-Search.OwnershipStatus="@Model.Search.OwnershipStatus"
                           asp-route-Search.Publisher="@Model.Search.Publisher"
                           asp-route-Search.ReleaseDateFrom="@Model.Search.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                           asp-route-Search.ReleaseDateTo="@Model.Search.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                           class="text-white text-decoration-none">
                            タイトル <i class="fas @SortIcon("title")"></i>
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-sort="mediatype" asp-route-sortdir="@SortDir("mediatype")"
                           asp-route-page="1" asp-route-Search.Keyword="@Model.Search.Keyword"
                           asp-route-Search.MediaType="@Model.Search.MediaType"
                           asp-route-Search.IsDigital="@Model.Search.IsDigital"
                           asp-route-Search.OwnershipStatus="@Model.Search.OwnershipStatus"
                           asp-route-Search.Publisher="@Model.Search.Publisher"
                           asp-route-Search.ReleaseDateFrom="@Model.Search.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                           asp-route-Search.ReleaseDateTo="@Model.Search.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                           class="text-white text-decoration-none">
                            種別 <i class="fas @SortIcon("mediatype")"></i>
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-sort="creator" asp-route-sortdir="@SortDir("creator")"
                           asp-route-page="1" asp-route-Search.Keyword="@Model.Search.Keyword"
                           asp-route-Search.MediaType="@Model.Search.MediaType"
                           asp-route-Search.IsDigital="@Model.Search.IsDigital"
                           asp-route-Search.OwnershipStatus="@Model.Search.OwnershipStatus"
                           asp-route-Search.Publisher="@Model.Search.Publisher"
                           asp-route-Search.ReleaseDateFrom="@Model.Search.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                           asp-route-Search.ReleaseDateTo="@Model.Search.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                           class="text-white text-decoration-none">
                            クリエイター <i class="fas @SortIcon("creator")"></i>
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-sort="ownershipstatus" asp-route-sortdir="@SortDir("ownershipstatus")"
                           asp-route-page="1" asp-route-Search.Keyword="@Model.Search.Keyword"
                           asp-route-Search.MediaType="@Model.Search.MediaType"
                           asp-route-Search.IsDigital="@Model.Search.IsDigital"
                           asp-route-Search.OwnershipStatus="@Model.Search.OwnershipStatus"
                           asp-route-Search.Publisher="@Model.Search.Publisher"
                           asp-route-Search.ReleaseDateFrom="@Model.Search.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                           asp-route-Search.ReleaseDateTo="@Model.Search.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                           class="text-white text-decoration-none">
                            ステータス <i class="fas @SortIcon("ownershipstatus")"></i>
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-sort="acquisitiondate" asp-route-sortdir="@SortDir("acquisitiondate")"
                           asp-route-page="1" asp-route-Search.Keyword="@Model.Search.Keyword"
                           asp-route-Search.MediaType="@Model.Search.MediaType"
                           asp-route-Search.IsDigital="@Model.Search.IsDigital"
                           asp-route-Search.OwnershipStatus="@Model.Search.OwnershipStatus"
                           asp-route-Search.Publisher="@Model.Search.Publisher"
                           asp-route-Search.ReleaseDateFrom="@Model.Search.ReleaseDateFrom?.ToString("yyyy-MM-dd")"
                           asp-route-Search.ReleaseDateTo="@Model.Search.ReleaseDateTo?.ToString("yyyy-MM-dd")"
                           class="text-white text-decoration-none">
                            取得日 <i class="fas @SortIcon("acquisitiondate")"></i>
                        </a>
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                @item.Title
                            </a>
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <span class="badge bg-secondary">@Html.DisplayFor(m => item.MediaType)</span>
                                @if (item.IsDigital)
                                {
                                    <span class="badge bg-info">デジタル</span>
                                }
                            </div>
                        </td>
                        <td>@item.Creator</td>
                        <td>@Html.DisplayFor(m => item.OwnershipStatus)</td>
                        <td>@item.AcquisitionDate?.ToString("yyyy/MM/dd")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="編集">
                                <i class="fas fa-pen"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="削除">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pager" model="pager" />
}
